# =============================================================================
# OPTIMA VIP — Environment variables
# Copy to `.env` for local dev and configure the same keys in Vercel.
# =============================================================================

# --- Database (Neon or Vercel Postgres) ---------------------------------------
# Use the POOLED connection string on Vercel (Neon `-pooler` host / PgBouncer)
# to avoid exhausting connections in serverless functions.
DATABASE_URL="postgresql://user:password@host:5432/optimavip?sslmode=require"

# --- Auth (NextAuth / Auth.js v5) ---------------------------------------------
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
# Public site URL (used for callbacks). On Vercel this is set automatically,
# but set it explicitly for custom domains.
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Maps (Leaflet + OpenStreetMap — no API key required) ---------------------
# Interactive maps use free OSM tiles via Leaflet. No Google Maps key needed.

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="OPTIMA VIP <no-reply@optimavip.com>"

# --- Telegram bot (webhook, no polling) ---------------------------------------
TELEGRAM_BOT_TOKEN=""
# Secret sent by Telegram in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=""

# --- Vercel Blob (image/video storage) ----------------------------------------
BLOB_READ_WRITE_TOKEN=""

# --- Cron (Vercel Cron Jobs) --------------------------------------------------
# Vercel sends `Authorization: Bearer <CRON_SECRET>` to protected cron routes.
CRON_SECRET="change-me"

# --- Seed (optional) ----------------------------------------------------------
# Used by prisma/seed.ts to create the initial admin account.
SEED_ADMIN_EMAIL="admin@optimavip.com"
SEED_ADMIN_PASSWORD="change-me-strong"
SEED_ADMIN_NAME="Administrador OPTIMA VIP"
